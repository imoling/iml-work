{
  "name": "iml-work-client",
  "version": "1.1.2",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "eval:router": "tsx scripts/eval-router.ts",
    "eval:ontology": "tsx scripts/eval-ontology.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.68.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "dingtalk-stream": "^2.1.6-beta.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.395.0",
    "pdfjs-dist": "^4.2.67",
    "playwright": "^1.44.1",
    "qq-official-bot": "^1.2.3",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^30.0.9",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.6",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "cn.imoling.imlwork",
    "productName": "iML Work",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "artifactName": "iML-Work-${version}-${os}-${arch}.${ext}",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.business",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "files": [
        "!**/node_modules/fsevents/**"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "iML Work"
    },
    "afterPack": "build/afterPack.cjs"
  }
}
